{
  "name": "exploratory-travel-dashboard",
  "version": "1.0.0",
  "description": "PrimePath Travel – Exploratory Travel Dashboard (SAP BTP + CAP + Fiori Elements)",
  "repository": "https://github.com/tombomeke-ehb/Exploratory-Travel-Dashboard",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4",
    "@sap/cds": "^9",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "express": "^4",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "[production]": {
          "kind": "hana"
        }
      },
      "TripPinService": {
        "kind": "odata-v4",
        "[production]": {
          "credentials": {
            "destination": "TripPinApi"
          }
        },
        "[development]": {
          "credentials": {
            "url": "https://services.odata.org/V4/TripPinServiceRW"
          }
        }
      }
    },
    "features": {
      "fetch_csrf": true
    }
  }
}
