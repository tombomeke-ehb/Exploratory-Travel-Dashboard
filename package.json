{
  "name": "exploratory-travel-dashboard",
  "version": "1.0.0",
  "description": "PrimePath Travel – Exploratory Travel Dashboard (SAP BTP + CAP + Fiori Elements)",
  "repository": "https://github.com/tombomeke-ehb/Exploratory-Travel-Dashboard",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/http-client": "^3",
    "@sap-cloud-sdk/resilience": "^3",
    "@sap/cds": "^8",
    "@sap/cds-dk": "^8",
    "@sap/xssec": "^4",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^1",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "[production]": {
          "kind": "hana"
        }
      },
      "TripPinService": {
        "kind": "odata-v4",
        "[production]": {
          "credentials": {
            "destination": "TripPinApi"
          }
        },
        "[development]": {
          "credentials": {
            "url": "https://services.odata.org/V4/TripPinServiceRW"
          }
        }
      },
      "[production]": {
        "auth": "xsuaa"
      }
    },
    "features": {
      "fetch_csrf": true
    }
  }
}
