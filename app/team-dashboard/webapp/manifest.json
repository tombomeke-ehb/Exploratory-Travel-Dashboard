{
  "_version": "1.65.0",
  "sap.app": {
    "id": "primepath.team",
    "type": "application",
    "title": "Team Dashboard",
    "description": "PrimePath Travel – Reisgoedkeuringen voor de Team Lead",
    "applicationVersion": { "version": "1.0.0" },
    "dataSources": {
      "TeamService": {
        "uri": "/team/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": { "icon": "sap-icon://group" }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.136.0",
      "libs": {
        "sap.fe.templates": {},
        "sap.ui.core": {},
        "sap.m": {},
        "sap.f": {}
      }
    },
    "models": {
      "": {
        "dataSource": "TeamService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": { "bundleName": "primepath.team.i18n.i18n" }
      }
    },
    "resources": {
      "css": [
        { "uri": "css/primepath.css" }
      ]
    },
    "routing": {
      "routes": [
        {
          "pattern": ":?query:",
          "name": "TripsList",
          "target": "TripsList"
        },
        {
          "pattern": "Trips({key}):?query:",
          "name": "TripsObjectPage",
          "target": "TripsObjectPage"
        },
        {
          "pattern": "People:?query:",
          "name": "PeopleList",
          "target": "PeopleList"
        },
        {
          "pattern": "People({key}):?query:",
          "name": "PeopleObjectPage",
          "target": "PeopleObjectPage"
        },
        {
          "pattern": "Airlines:?query:",
          "name": "AirlinesList",
          "target": "AirlinesList"
        },
        {
          "pattern": "Airlines({key}):?query:",
          "name": "AirlinesObjectPage",
          "target": "AirlinesObjectPage"
        },
        {
          "pattern": "TravelExtensions:?query:",
          "name": "TravelExtensionsList",
          "target": "TravelExtensionsList"
        },
        {
          "pattern": "TravelExtensions({key}):?query:",
          "name": "TravelExtensionsObjectPage",
          "target": "TravelExtensionsObjectPage"
        }
      ],
      "targets": {
        "TripsList": {
          "type": "Component",
          "id": "TripsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "Trips",
              "variantManagement": "None",
              "initialLoad": "Enabled",
              "navigation": {
                "Trips": { "detail": { "route": "TripsObjectPage" } }
              }
            }
          }
        },
        "TripsObjectPage": {
          "type": "Component",
          "id": "TripsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "Trips",
              "editableHeaderContent": false
            }
          }
        },
        "PeopleList": {
          "type": "Component",
          "id": "PeopleList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "People",
              "variantManagement": "None",
              "initialLoad": "Enabled",
              "navigation": {
                "People": { "detail": { "route": "PeopleObjectPage" } }
              }
            }
          }
        },
        "PeopleObjectPage": {
          "type": "Component",
          "id": "PeopleObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "People",
              "editableHeaderContent": false
            }
          }
        },
        "AirlinesList": {
          "type": "Component",
          "id": "AirlinesList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "Airlines",
              "variantManagement": "None",
              "initialLoad": "Enabled",
              "navigation": {
                "Airlines": { "detail": { "route": "AirlinesObjectPage" } }
              }
            }
          }
        },
        "AirlinesObjectPage": {
          "type": "Component",
          "id": "AirlinesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "Airlines",
              "editableHeaderContent": false
            }
          }
        },
        "TravelExtensionsList": {
          "type": "Component",
          "id": "TravelExtensionsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "TravelExtensions",
              "variantManagement": "None",
              "initialLoad": "Enabled",
              "navigation": {
                "TravelExtensions": { "detail": { "route": "TravelExtensionsObjectPage" } }
              }
            }
          }
        },
        "TravelExtensionsObjectPage": {
          "type": "Component",
          "id": "TravelExtensionsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "TravelExtensions",
              "editableHeaderContent": false
            }
          }
        }
      }
    }
  }
}
