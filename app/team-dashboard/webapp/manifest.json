{
  "_version": "1.65.0",
  "sap.app": {
    "id": "primepath.team",
    "type": "application",
    "title": "Team Dashboard",
    "description": "PrimePath Travel – Reisgoedkeuringen voor de Team Lead",
    "applicationVersion": { "version": "1.0.0" },
    "dataSources": {
      "TeamService": {
        "uri": "/team/",
        "type": "OData",
        "settings": { "odataVersion": "4.0" }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": { "icon": "sap-icon://group" }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.130.0",
      "libs": {
        "sap.fe.templates": {},
        "sap.ui.core": {},
        "sap.m": {},
        "sap.f": {}
      }
    },
    "models": {
      "": {
        "dataSource": "TeamService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": { "bundleName": "primepath.team.i18n.i18n" }
      }
    },
    "routing": {
      "routes": [
        {
          "pattern": ":?query:",
          "name": "TripsList",
          "target": "TripsList"
        },
        {
          "pattern": "Trips({key}):?query:",
          "name": "TripsObjectPage",
          "target": "TripsObjectPage"
        }
      ],
      "targets": {
        "TripsList": {
          "type": "Component",
          "id": "TripsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "Trips",
              "variantManagement": "Page",
              "initialLoad": "Enabled",
              "navigation": {
                "Trips": { "detail": { "route": "TripsObjectPage" } }
              }
            }
          }
        },
        "TripsObjectPage": {
          "type": "Component",
          "id": "TripsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "Trips",
              "editableHeaderContent": false
            }
          }
        }
      }
    }
  }
}
